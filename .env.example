# ─────────────────────────────────────────────────────────────────────────────
# Mission Control — Variables de entorno
# Copiá este archivo como ".env" y completá tus tokens.
# El archivo .env NUNCA se sube a GitHub (está en .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# [REQUERIDO] Token de GitHub para GitHub Models API (gratis con cualquier cuenta)
# Obtenerlo en: https://github.com/settings/tokens
# Formato: ghp_xxxxxxxxxxxx o github_pat_xxxxxxxxxxxx
GITHUB_TOKEN=

# [OPCIONAL] OpenAI directo (sin pasar por GitHub Models)
# Obtenerlo en: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# [OPCIONAL] Anthropic Claude directo
# Obtenerlo en: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# [OPCIONAL] Integración Jira
# Tu instancia: https://tu-empresa.atlassian.net
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_TOKEN=

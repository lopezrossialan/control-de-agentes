# Credenciales - NUNCA subir
.env

# Historial de chats (datos personales, persistencia local)
chats/

# Dependencias
node_modules/

# Outputs generados (contienen datos reales, no subir)
outputs/

# Archivos de entrada (pueden contener docs confidenciales)
inputs/

# VS Code / MCP (configuración local)
.vscode/

# Sistema
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
npm-debug.log*

# Presentaciones y generador (archivos locales)
*.pptx
*.pdf
generate_presentation.py
generate_manual.py

# Build outputs
build/
# Excluir .exe en subcarpetas pero permitir el de la raiz
